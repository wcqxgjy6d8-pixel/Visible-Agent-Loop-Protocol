{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VALP Historical Audit Boundary",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "recorded_at",
    "decision_task_id",
    "decision_ref",
    "auditor_boundary",
    "accepted_legacy_artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "valp-historical-audit-boundary.v1"
    },
    "task_id": {"type": "string", "minLength": 1},
    "recorded_at": {"type": "string", "minLength": 1},
    "decision_task_id": {"type": "string", "minLength": 1},
    "decision_ref": {
      "type": "string",
      "pattern": "^\\.herdr-loop/tasks/(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "auditor_boundary": {
      "type": "object",
      "required": [
        "historical_cli_version",
        "historical_source_revision",
        "rule_introduced_revision"
      ],
      "properties": {
        "historical_cli_version": {"type": "string", "minLength": 1},
        "historical_source_revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "rule_introduced_revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      },
      "additionalProperties": false
    },
    "accepted_legacy_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "agent",
          "artifact_ref",
          "byte_digest",
          "recorded_budget",
          "observed",
          "disposition",
          "reason"
        ],
        "properties": {
          "rule_id": {"const": "context_pack.dispatch_payload_budget"},
          "agent": {"type": "string", "minLength": 1},
          "artifact_ref": {
            "type": "string",
            "pattern": "^(?!/)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)(?:\\.{0,2})(?:/|$)).+$"
          },
          "byte_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "recorded_budget": {
            "$ref": "#/$defs/recordedBudget"
          },
          "observed": {
            "$ref": "#/$defs/observedMeasurement"
          },
          "disposition": {"const": "accept_historical_artifact"},
          "reason": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "recordedBudget": {
      "type": "object",
      "required": [
        "role",
        "max_chars",
        "max_reference_tokens",
        "token_estimator",
        "actual_chars",
        "actual_reference_tokens",
        "dispatch_ref"
      ],
      "properties": {
        "role": {"enum": ["coordinator", "implementer", "reviewer", "prototype", "researcher", "other"]},
        "max_chars": {"type": "integer", "minimum": 1},
        "max_reference_tokens": {"type": "integer", "minimum": 1},
        "token_estimator": {"const": "ceil(chars/4)"},
        "actual_chars": {"type": "integer", "minimum": 1},
        "actual_reference_tokens": {"type": "integer", "minimum": 1},
        "dispatch_ref": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "observedMeasurement": {
      "type": "object",
      "required": ["actual_chars", "actual_reference_tokens"],
      "properties": {
        "actual_chars": {"type": "integer", "minimum": 1},
        "actual_reference_tokens": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
