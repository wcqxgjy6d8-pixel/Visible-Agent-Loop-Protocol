{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VALP Routing Feedback",
  "type": "object",
  "required": ["schema_version", "task_id", "profile", "result", "updated_at"],
  "properties": {
    "schema_version": {
      "const": "valp-routing-feedback.v1"
    },
    "task_id": {"type": "string"},
    "profile": {"type": "string"},
    "selected_agents": {"type": "array", "items": {"type": "string"}},
    "candidate_agents": {"type": "array", "items": {"type": "string"}},
    "routing_confidence": {"type": "object"},
    "expected_evidence": {"type": "array", "items": {"type": "string"}},
    "actual_evidence": {"type": "array", "items": {"type": "string"}},
    "verification_result": {"type": "string"},
    "review_result": {"type": "string"},
    "approval_outcomes": {"type": "array", "items": {"type": "object"}},
    "blockers": {"type": "array", "items": {"type": "object"}},
    "result": {
      "enum": ["done", "blocked", "failed", "cancelled", "partial"]
    },
    "lessons": {"type": "array", "items": {"type": "string"}},
    "next_routing_hints": {"type": "array", "items": {"type": "string"}},
    "privacy_notes": {"type": "array", "items": {"type": "string"}},
    "updated_at": {"type": "string"}
  }
}
