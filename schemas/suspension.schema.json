{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:valp:schema:deterministic-suspension:v1",
  "title": "VALP Deterministic Suspension",
  "type": "object",
  "required": [
    "status",
    "suspension_id",
    "suspension_epoch",
    "state_revision_at_entry",
    "wait_policy_ref",
    "wait_policy_id",
    "strict_identity",
    "event_sequence_at_entry",
    "receipt_event_sequence_at_entry",
    "receipt_cursor_at_entry",
    "required_work_items",
    "required_work_item_ids",
    "pending_work_item_ids",
    "completed_work_item_ids",
    "failed_work_item_ids",
    "entered_at",
    "deadline_at",
    "execution_deadline",
    "waiting_for_agents",
    "receipt_count_at_entry",
    "allowed_resume_events"
  ],
  "properties": {
    "status": {"enum": ["waiting", "resumed"]},
    "suspension_id": {"$ref": "#/$defs/digestId"},
    "suspension_epoch": {"type": "integer", "minimum": 1},
    "state_revision_at_entry": {"type": "integer", "minimum": 0},
    "checkpoint_ref": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)(?:\\.{0,2})(?:/|$)).+$"
    },
    "wait_policy_ref": {
      "type": ["string", "null"],
      "pattern": "^wait-policies/[0-9a-f]{64}\\.json$"
    },
    "wait_policy_id": {"type": "string", "minLength": 1},
    "strict_identity": {"type": "boolean"},
    "event_sequence_at_entry": {"type": "integer", "minimum": 0},
    "receipt_event_sequence_at_entry": {"type": "integer", "minimum": 0},
    "receipt_cursor_at_entry": {"type": "integer", "minimum": 0},
    "receipt_cursor": {"type": "integer", "minimum": 0},
    "required_work_items": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/workItem"}
    },
    "required_work_item_ids": {"$ref": "#/$defs/workItemIds"},
    "pending_work_item_ids": {"$ref": "#/$defs/workItemIds"},
    "completed_work_item_ids": {"$ref": "#/$defs/workItemIds"},
    "failed_work_item_ids": {"$ref": "#/$defs/workItemIds"},
    "entered_at": {"type": "string", "minLength": 1},
    "deadline_at": {"type": "string", "minLength": 1},
    "execution_deadline": {"type": "string", "minLength": 1},
    "waiting_for_agents": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "receipt_count_at_entry": {"type": "integer", "minimum": 0},
    "evidence_refs_present_at_entry": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?!/)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)(?:\\.{0,2})(?:/|$)).+$"
      }
    },
    "allowed_resume_events": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": ["receipt", "timeout", "runtime_failure", "cancellation", "user_input"]
      }
    },
    "resume_event": {
      "enum": ["receipt", "timeout", "runtime_failure", "cancellation", "user_input"]
    },
    "resumed_at": {"type": "string", "minLength": 1},
    "resume_ref": {"type": "string", "minLength": 1},
    "accepted_wake": {"$ref": "#/$defs/acceptedWake"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "resumed"}}, "required": ["status"]},
      "then": {"required": ["resume_event", "resumed_at", "accepted_wake"]},
      "else": {"not": {"required": ["accepted_wake"]}}
    },
    {
      "if": {"properties": {"strict_identity": {"const": true}}, "required": ["strict_identity"]},
      "then": {
        "properties": {
          "wait_policy_ref": {
            "type": "string",
            "pattern": "^wait-policies/[0-9a-f]{64}\\.json$"
          }
        }
      },
      "else": {"properties": {"wait_policy_ref": {"type": "null"}}}
    }
  ],
  "additionalProperties": false,
  "$defs": {
    "workItem": {
      "type": "object",
      "required": [
        "work_item_id",
        "agent",
        "role",
        "dispatch_id",
        "dispatch_generation",
        "expected_refs"
      ],
      "properties": {
        "work_item_id": {"type": "string", "minLength": 1},
        "agent": {"type": "string", "minLength": 1},
        "role": {
          "enum": ["coordinator", "implementer", "reviewer", "prototype", "researcher", "other"]
        },
        "dispatch_id": {"type": "string", "minLength": 1},
        "dispatch_generation": {"type": "integer", "minimum": 1},
        "expected_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "acceptedWake": {
      "type": "object",
      "required": [
        "wake_id",
        "wake_event_id",
        "wake_reason",
        "resume_event",
        "resume_ref",
        "accepted_sequence",
        "resulting_state_revision",
        "result_ref"
      ],
      "properties": {
        "wake_id": {"$ref": "#/$defs/digestId"},
        "wake_event_id": {"$ref": "#/$defs/digestId"},
        "wake_reason": {
          "enum": [
            "dependency_ready",
            "dispatch_blocked",
            "manual_blocked",
            "timeout",
            "runtime_failure",
            "cancellation",
            "user_input"
          ]
        },
        "resume_event": {
          "enum": ["receipt", "timeout", "runtime_failure", "cancellation", "user_input"]
        },
        "resume_ref": {"type": ["string", "null"]},
        "accepted_sequence": {"type": "integer", "minimum": 1},
        "resulting_state_revision": {"type": "integer", "minimum": 1},
        "result_ref": {"type": "string", "pattern": "^wake-results/[0-9a-f]{64}\\.json$"},
        "external_event": {"$ref": "#/$defs/externalEvent"}
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "resume_event": {"enum": ["runtime_failure", "cancellation", "user_input"]}
            },
            "required": ["resume_event"]
          },
          "then": {"required": ["external_event"]}
        },
        {
          "oneOf": [
            {
              "properties": {
                "resume_event": {"const": "receipt"},
                "wake_reason": {"enum": ["dependency_ready", "dispatch_blocked", "manual_blocked"]}
              }
            },
            {
              "properties": {
                "resume_event": {"const": "timeout"},
                "wake_reason": {"const": "timeout"}
              }
            },
            {
              "properties": {
                "resume_event": {"const": "runtime_failure"},
                "wake_reason": {"const": "runtime_failure"}
              }
            },
            {
              "properties": {
                "resume_event": {"const": "cancellation"},
                "wake_reason": {"const": "cancellation"}
              }
            },
            {
              "properties": {
                "resume_event": {"const": "user_input"},
                "wake_reason": {"const": "user_input"}
              }
            }
          ]
        }
      ],
      "additionalProperties": false
    },
    "externalEvent": {
      "type": "object",
      "required": [
        "source_ref",
        "source_digest",
        "principal",
        "reason",
        "recorded_at",
        "supporting_refs"
      ],
      "properties": {
        "source_ref": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)(?:\\.{0,2})(?:/|$)).+$"
        },
        "source_digest": {"$ref": "#/$defs/digestId"},
        "principal": {
          "type": "object",
          "required": ["type", "id"],
          "properties": {
            "type": {"enum": ["user", "runtime", "policy"]},
            "id": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        },
        "reason": {"type": "string", "minLength": 1},
        "recorded_at": {"type": "string", "minLength": 1},
        "supporting_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^(?!/)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)(?:\\.{0,2})(?:/|$)).+$"
          }
        }
      },
      "additionalProperties": false
    },
    "digestId": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "workItemIds": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
