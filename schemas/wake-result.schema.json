{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VALP Wake Result",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "suspension_id",
    "suspension_epoch",
    "wake_id",
    "wake_event_id",
    "wake_reason",
    "resume_event",
    "resume_ref",
    "accepted_sequence",
    "resulting_state_revision",
    "result_ref",
    "resulting_task_status",
    "completed_work_item_ids",
    "pending_work_item_ids",
    "failed_work_item_ids",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {"const": "valp-wake-result.v1"},
    "task_id": {"type": "string", "minLength": 1},
    "suspension_id": {"$ref": "#/$defs/digestId"},
    "suspension_epoch": {"type": "integer", "minimum": 1},
    "wake_id": {"$ref": "#/$defs/digestId"},
    "wake_event_id": {"$ref": "#/$defs/digestId"},
    "wake_reason": {
      "enum": [
        "dependency_ready",
        "dispatch_blocked",
        "manual_blocked",
        "timeout",
        "runtime_failure",
        "cancellation",
        "user_input"
      ]
    },
    "resume_event": {
      "enum": ["receipt", "timeout", "runtime_failure", "cancellation", "user_input"]
    },
    "resume_ref": {
      "type": ["string", "null"],
      "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "accepted_sequence": {"type": "integer", "minimum": 1},
    "resulting_state_revision": {"type": "integer", "minimum": 1},
    "result_ref": {
      "type": "string",
      "pattern": "^wake-results/[0-9a-f]{64}\\.json$"
    },
    "resulting_task_status": {"enum": ["executing", "blocked", "cancelled"]},
    "completed_work_item_ids": {"$ref": "#/$defs/workItemIds"},
    "pending_work_item_ids": {"$ref": "#/$defs/workItemIds"},
    "failed_work_item_ids": {"$ref": "#/$defs/workItemIds"},
    "recorded_at": {"type": "string", "minLength": 1},
    "external_event": {"$ref": "#/$defs/externalEvent"}
  },
  "$defs": {
    "digestId": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "workItemIds": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "externalEvent": {
      "type": "object",
      "required": ["source_ref", "source_digest", "principal", "reason", "recorded_at", "supporting_refs"],
      "properties": {
        "source_ref": {"type": "string", "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
        "source_digest": {"$ref": "#/$defs/digestId"},
        "principal": {
          "type": "object",
          "required": ["type", "id"],
          "properties": {
            "type": {"enum": ["user", "runtime", "policy"]},
            "id": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        },
        "reason": {"type": "string", "minLength": 1},
        "recorded_at": {"type": "string", "minLength": 1},
        "supporting_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"}
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "resume_event": {"enum": ["runtime_failure", "cancellation", "user_input"]}
        },
        "required": ["resume_event"]
      },
      "then": {"required": ["external_event"]}
    },
    {
      "oneOf": [
        {
          "properties": {
            "resume_event": {"const": "receipt"},
            "wake_reason": {"enum": ["dependency_ready", "dispatch_blocked", "manual_blocked"]}
          }
        },
        {
          "properties": {
            "resume_event": {"const": "timeout"},
            "wake_reason": {"const": "timeout"}
          }
        },
        {
          "properties": {
            "resume_event": {"const": "runtime_failure"},
            "wake_reason": {"const": "runtime_failure"}
          }
        },
        {
          "properties": {
            "resume_event": {"const": "cancellation"},
            "wake_reason": {"const": "cancellation"}
          }
        },
        {
          "properties": {
            "resume_event": {"const": "user_input"},
            "wake_reason": {"const": "user_input"}
          }
        }
      ]
    },
    {
      "oneOf": [
        {
          "properties": {
            "wake_reason": {"enum": ["dependency_ready", "user_input"]},
            "resulting_task_status": {"const": "executing"}
          }
        },
        {
          "properties": {
            "wake_reason": {
              "enum": ["dispatch_blocked", "manual_blocked", "timeout", "runtime_failure"]
            },
            "resulting_task_status": {"const": "blocked"}
          }
        },
        {
          "properties": {
            "wake_reason": {"const": "cancellation"},
            "resulting_task_status": {"const": "cancelled"}
          }
        }
      ]
    }
  ],
  "additionalProperties": false
}
