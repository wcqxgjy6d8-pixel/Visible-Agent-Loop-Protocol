{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VALP Submission Dependencies",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "ordering_source",
    "dependencies"
  ],
  "properties": {
    "schema_version": {
      "const": "valp-submission-dependencies.v1"
    },
    "task_id": {"type": "string", "minLength": 1},
    "ordering_source": {
      "const": "dispatch-receipts.jsonl#line-order"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "prerequisite_role",
          "prerequisite_agent",
          "dependent_role",
          "dependent_agent",
          "prerequisite_refs",
          "dependent_refs"
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "prerequisite_role": {
            "enum": ["coordinator", "implementer", "reviewer", "prototype", "researcher"]
          },
          "prerequisite_agent": {"type": "string", "minLength": 1},
          "dependent_role": {
            "enum": ["coordinator", "implementer", "reviewer", "prototype", "researcher"]
          },
          "dependent_agent": {"type": "string", "minLength": 1},
          "prerequisite_refs": {
            "$ref": "#/$defs/evidenceRefs"
          },
          "dependent_refs": {
            "$ref": "#/$defs/evidenceRefs"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
      }
    }
  },
  "additionalProperties": false
}
