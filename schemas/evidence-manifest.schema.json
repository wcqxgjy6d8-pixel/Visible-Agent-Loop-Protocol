{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valp.dev/schema/valp-evidence-manifest.v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "installation_id", "items"],
  "properties": {
    "schema_version": {"const": "valp-evidence-manifest.v1"},
    "installation_id": {"type": "string", "minLength": 1},
    "items": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["evidence_id", "evidence_kind", "content_ref", "content_digest", "media_type", "byte_length", "created_at", "producer_principal_id", "collection_method", "redaction_state", "validity_state", "supporting_claim_ids"], "properties": {"evidence_id": {"type": "string", "minLength": 1}, "evidence_kind": {"type": "string", "minLength": 1}, "content_ref": {"type": "string", "minLength": 1}, "content_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "media_type": {"type": "string", "minLength": 1}, "byte_length": {"type": "integer", "minimum": 0}, "created_at": {"type": "string", "minLength": 1}, "producer_principal_id": {"type": "string", "minLength": 1}, "collection_method": {"type": "string", "minLength": 1}, "redaction_state": {"type": "string", "minLength": 1}, "validity_state": {"enum": ["valid", "invalid", "superseded", "rejected", "blocked"]}, "supporting_claim_ids": {"type": "array", "items": {"type": "string", "minLength": 1}}}}}
  }
}
