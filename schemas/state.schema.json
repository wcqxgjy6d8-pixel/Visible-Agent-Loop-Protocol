{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VALP Task State",
  "type": "object",
  "required": ["schema_version", "task_id", "profile", "status", "selected_agents"],
  "properties": {
    "schema_version": {
      "const": "valp-visible-loop-state.v1"
    },
    "task_id": {"type": "string"},
    "profile": {"type": "string"},
    "loop_layer": {"type": "string"},
    "status": {
      "type": "string",
      "description": "Includes the non-terminal suspended state when a runtime pauses coordinator model turns."
    },
    "risk": {"type": "object"},
    "selected_agents": {
      "type": "array",
      "items": {"type": "string"}
    },
    "role_assignments": {"type": "object"},
    "capabilities_needed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "capabilities_missing": {
      "type": "array",
      "items": {"type": "string"}
    },
    "runtime_adapter": {"type": "object"},
    "local_overlay": {"type": "object"},
    "runtime_task_state_mapping": {"type": "object"},
    "provider_matrix": {"type": "object"},
    "squad_routing": {"type": "object"},
    "context_policies": {"type": "object"},
    "automation_policy": {"type": "object"},
    "context_pack": {"type": "object"},
    "dispatch_payload_budgets": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/dispatchPayloadBudget"}
    },
    "suspension": {
      "type": "object",
      "required": [
        "status",
        "entered_at",
        "deadline_at",
        "waiting_for_agents",
        "receipt_count_at_entry",
        "allowed_resume_events"
      ],
      "properties": {
        "status": {"enum": ["waiting", "resumed"]},
        "entered_at": {"type": "string"},
        "deadline_at": {"type": "string"},
        "waiting_for_agents": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "receipt_count_at_entry": {"type": "integer", "minimum": 0},
        "allowed_resume_events": {
          "type": "array",
          "items": {
            "enum": ["receipt", "timeout", "runtime_failure", "cancellation", "user_input"]
          }
        },
        "resume_event": {
          "enum": ["receipt", "timeout", "runtime_failure", "cancellation", "user_input"]
        },
        "resumed_at": {"type": "string"},
        "resume_ref": {"type": "string"}
      },
      "additionalProperties": false
    },
    "skill_recommendations": {"type": "object"},
    "visible_attention": {"type": "object"},
    "routing_confidence": {"type": "object"},
    "routing_feedback": {"type": "object"},
    "learning_feedback": {"type": "object"},
    "gates": {"type": "object"},
    "approval_required": {"type": "array"},
    "updated_at": {"type": "string"}
  },
  "$defs": {
    "dispatchPayloadBudget": {
      "type": "object",
      "required": ["role", "max_chars", "max_reference_tokens", "token_estimator"],
      "properties": {
        "role": {"enum": ["coordinator", "implementer", "reviewer", "prototype", "researcher", "other"]},
        "max_chars": {"type": "integer", "minimum": 1},
        "max_reference_tokens": {"type": "integer", "minimum": 1},
        "token_estimator": {"const": "ceil(chars/4)"},
        "actual_chars": {"type": "integer", "minimum": 1},
        "actual_reference_tokens": {"type": "integer", "minimum": 1},
        "dispatch_ref": {"type": "string"}
      },
      "additionalProperties": false
    }
  }
}
