{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VALP Wait Policy",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "wait_policy_id",
    "mode",
    "exception_policy",
    "dependency_ref",
    "required_work_items",
    "exception_events"
  ],
  "properties": {
    "schema_version": {"const": "valp-wait-policy.v1"},
    "task_id": {"type": "string", "minLength": 1},
    "wait_policy_id": {"type": "string", "minLength": 1},
    "mode": {"const": "dependency_ready"},
    "exception_policy": {"const": "exception_short_circuit"},
    "dependency_ref": {"const": "submission-dependencies.json"},
    "required_work_items": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/workItem"}
    },
    "exception_events": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {
        "enum": [
          "dispatch_blocked",
          "manual_blocked",
          "runtime_failure",
          "cancellation",
          "timeout",
          "user_input"
        ]
      },
      "allOf": [
        {"contains": {"const": "dispatch_blocked"}},
        {"contains": {"const": "runtime_failure"}},
        {"contains": {"const": "cancellation"}},
        {"contains": {"const": "timeout"}},
        {"contains": {"const": "user_input"}}
      ]
    }
  },
  "$defs": {
    "workItem": {
      "type": "object",
      "required": [
        "work_item_id",
        "agent",
        "role",
        "dispatch_id",
        "dispatch_generation",
        "expected_refs"
      ],
      "properties": {
        "work_item_id": {"type": "string", "minLength": 1},
        "agent": {"type": "string", "minLength": 1},
        "role": {
          "enum": ["coordinator", "implementer", "reviewer", "prototype", "researcher", "other"]
        },
        "dispatch_id": {"type": "string", "minLength": 1},
        "dispatch_generation": {"type": "integer", "minimum": 1},
        "expected_refs": {"$ref": "#/$defs/evidenceRefs"}
      },
      "additionalProperties": false
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
      }
    }
  },
  "additionalProperties": false
}
