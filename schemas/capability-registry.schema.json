{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valp.dev/schema/valp-capability-registry.v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "installation_id", "registry_revision", "last_observation_sequence", "generated_at", "active_leader_epoch", "entries", "projection_digest"],
  "properties": {
    "schema_version": {"const": "valp-capability-registry.v1"},
    "installation_id": {"type": "string", "minLength": 1},
    "registry_revision": {"type": "integer", "minimum": 0},
    "last_observation_sequence": {"type": "integer", "minimum": 0},
    "generated_at": {"type": "string", "minLength": 1},
    "active_leader_epoch": {"type": "integer", "minimum": 0},
    "entries": {"type": "object", "additionalProperties": {"type": "object", "required": ["subject_id", "capability_id", "layers", "effective_status"], "properties": {"subject_id": {"type": "string", "minLength": 1}, "capability_id": {"type": "string", "minLength": 1}, "layers": {"type": "object"}, "effective_status": {"type": "string", "minLength": 1}}}},
    "projection_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
