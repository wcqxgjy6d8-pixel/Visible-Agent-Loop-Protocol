{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valp.dev/schema/valp-evidence-catalog-fixtures.v1.json",
  "title": "VALP Anonymous Evidence Catalog Fixtures",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "anonymousMetadataValue": {
      "anyOf": [
        {"type": ["string", "number", "boolean", "null"]},
        {
          "type": "array",
          "items": {"$ref": "#/$defs/anonymousMetadataValue"}
        },
        {"$ref": "#/$defs/anonymousMetadataObject"}
      ]
    },
    "anonymousMetadataObject": {
      "type": "object",
      "propertyNames": {
        "not": {
          "enum": [
            "task",
            "task_id",
            "source",
            "source_ref",
            "path",
            "agent",
            "dispatch_id",
            "tool_call_id",
            "user",
            "user_id"
          ]
        }
      },
      "additionalProperties": {"$ref": "#/$defs/anonymousMetadataValue"}
    }
  },
  "required": ["schema_version", "fixtures"],
  "properties": {
    "schema_version": {"const": "valp-evidence-catalog-fixtures.v1"},
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fixture_id",
          "source_ref",
          "evidence_type",
          "status",
          "depends_on",
          "metadata"
        ],
        "properties": {
          "fixture_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "source_ref": {
            "type": "string",
            "pattern": "^(?!/)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)(?:\\.{0,2})(?:/|$)).+$"
          },
          "evidence_type": {"type": "string", "minLength": 1},
          "status": {"enum": ["valid", "stale", "invalid"]},
          "depends_on": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
            }
          },
          "metadata": {"$ref": "#/$defs/anonymousMetadataObject"}
        }
      }
    }
  }
}
