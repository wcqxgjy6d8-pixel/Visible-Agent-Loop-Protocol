{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VALP Routing",
  "type": "object",
  "required": ["schema_version", "task_id", "profile", "selected_agents"],
  "properties": {
    "schema_version": {
      "const": "valp-capability-routing.v1"
    },
    "task_id": {"type": "string"},
    "profile": {"type": "string"},
    "runtime_adapter": {"type": "object"},
    "local_overlay": {"type": "object"},
    "routing_reason": {"type": "string"},
    "capabilities_needed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "role_requirements": {
      "type": "array",
      "items": {"type": "string"}
    },
    "role_assignments": {"type": "object"},
    "model_role_gate": {
      "type": "object",
      "required": ["enforced", "status", "blocked_roles", "fallback_modes", "reason"],
      "properties": {
        "enforced": {"type": "boolean"},
        "status": {"enum": ["pass", "blocked"]},
        "blocked_roles": {"type": "array", "items": {"enum": ["implementer", "reviewer"]}},
        "fallback_modes": {"type": "array", "items": {"enum": ["discovery", "prototype", "manual"]}},
        "reason": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "submission_dependencies": {
      "type": "object",
      "required": ["status", "ref"],
      "properties": {
        "status": {"const": "recorded"},
        "ref": {"const": "submission-dependencies.json"}
      },
      "additionalProperties": false
    },
    "delegation_policy": {
      "type": "object",
      "required": ["status", "ref"],
      "properties": {
        "status": {"const": "recorded"},
        "ref": {"const": "delegation-policy.json"}
      },
      "additionalProperties": false
    },
    "coordinator_selection": {"type": "object"},
    "selected_agents": {
      "type": "array",
      "items": {"type": "string"}
    },
    "agent_match_reasons": {"type": "object"},
    "candidate_scores": {"type": "object"},
    "routing_confidence": {"type": "object"},
    "rejected_candidates": {
      "type": "array",
      "items": {"type": "object"}
    },
    "selected_agent_context_policies": {"type": "object"},
    "automation_policy": {"type": "object"},
    "context_pack": {"type": "object"},
    "dispatch_payload_budgets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["role", "max_chars", "max_reference_tokens", "token_estimator", "actual_chars", "actual_reference_tokens", "dispatch_ref"],
        "properties": {
          "role": {"enum": ["coordinator", "implementer", "reviewer", "prototype", "researcher", "other"]},
          "max_chars": {"type": "integer", "minimum": 1},
          "max_reference_tokens": {"type": "integer", "minimum": 1},
          "token_estimator": {"const": "ceil(chars/4)"},
          "actual_chars": {"type": "integer", "minimum": 1},
          "actual_reference_tokens": {"type": "integer", "minimum": 1},
          "dispatch_ref": {"type": "string"},
          "skill_slice_ref": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    },
    "iteration_budget": {
      "type": "object",
      "required": ["status", "ref"],
      "properties": {
        "status": {"const": "recorded"},
        "ref": {"const": "iteration-budget.json"}
      },
      "additionalProperties": false
    },
    "skill_recommendation_slices": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "skill_recommendations": {"type": "object"},
    "visible_attention": {"type": "object"},
    "provider_matrix": {
      "type": "object",
      "properties": {
        "model_awareness": {"type": "object"},
        "providers": {"type": "object"}
      }
    },
    "runtime_task_state_mapping": {"type": "object"},
    "squad_routing": {"type": "object"},
    "routing_feedback_ref": {"type": "string"},
    "learning_feedback_ref": {"type": "string"},
    "capabilities_missing": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
