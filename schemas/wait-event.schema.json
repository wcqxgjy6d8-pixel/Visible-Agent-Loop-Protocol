{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VALP Wait Event",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "event_id",
    "event_sequence",
    "event",
    "recorded_at",
    "state_revision_before",
    "state_revision_after",
    "suspension_id",
    "suspension_epoch",
    "projection"
  ],
  "properties": {
    "schema_version": {"const": "valp-wait-event.v1"},
    "task_id": {"type": "string", "minLength": 1},
    "event_id": {"$ref": "#/$defs/digestId"},
    "event_sequence": {"type": "integer", "minimum": 1},
    "event": {"enum": ["coordinator_suspended", "work_item_completed", "coordinator_resumed"]},
    "recorded_at": {"type": "string", "minLength": 1},
    "state_revision_before": {"type": "integer", "minimum": 0},
    "state_revision_after": {"type": "integer", "minimum": 1},
    "suspension_id": {"$ref": "#/$defs/digestId"},
    "suspension_epoch": {"type": "integer", "minimum": 1},
    "projection": {
      "type": "object",
      "required": ["status", "suspension", "updated_at"],
      "properties": {
        "status": {"type": "string", "minLength": 1},
        "suspension": {"$ref": "urn:valp:schema:deterministic-suspension:v1"},
        "updated_at": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "work_item_id": {"type": "string", "minLength": 1},
    "qualifying_receipt_id": {"type": ["string", "null"]},
    "receipt_ref": {"type": "string", "minLength": 1},
    "resume_event": {
      "enum": ["receipt", "timeout", "runtime_failure", "cancellation", "user_input"]
    },
    "resume_ref": {"type": ["string", "null"]},
    "wake_reason": {
      "enum": [
        "dependency_ready",
        "dispatch_blocked",
        "manual_blocked",
        "timeout",
        "runtime_failure",
        "cancellation",
        "user_input"
      ]
    },
    "wake_id": {"$ref": "#/$defs/digestId"},
    "result_ref": {"type": "string", "pattern": "^wake-results/[0-9a-f]{64}\\.json$"},
    "external_event": {"$ref": "#/$defs/externalEvent"}
  },
  "$defs": {
    "digestId": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "externalEvent": {
      "type": "object",
      "required": ["source_ref", "source_digest", "principal", "reason", "recorded_at", "supporting_refs"],
      "properties": {
        "source_ref": {"type": "string", "pattern": "^(?!/)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)(?:\\.{0,2})(?:/|$)).+$"},
        "source_digest": {"$ref": "#/$defs/digestId"},
        "principal": {
          "type": "object",
          "required": ["type", "id"],
          "properties": {
            "type": {"enum": ["user", "runtime", "policy"]},
            "id": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        },
        "reason": {"type": "string", "minLength": 1},
        "recorded_at": {"type": "string", "minLength": 1},
        "supporting_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^(?!/)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)(?:\\.{0,2})(?:/|$)).+$"}
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {"properties": {"event": {"const": "work_item_completed"}}},
      "then": {"required": ["work_item_id", "qualifying_receipt_id", "receipt_ref"]}
    },
    {
      "if": {"properties": {"event": {"const": "coordinator_resumed"}}},
      "then": {
        "required": [
          "resume_event",
          "resume_ref",
          "wake_reason",
          "wake_id",
          "result_ref",
          "qualifying_receipt_id"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "event": {"const": "coordinator_resumed"},
          "resume_event": {"enum": ["runtime_failure", "cancellation", "user_input"]}
        },
        "required": ["event", "resume_event"]
      },
      "then": {"required": ["external_event"]}
    },
    {
      "if": {
        "properties": {"event": {"const": "coordinator_resumed"}},
        "required": ["event"]
      },
      "then": {
        "oneOf": [
          {
            "properties": {
              "resume_event": {"const": "receipt"},
              "wake_reason": {"enum": ["dependency_ready", "dispatch_blocked", "manual_blocked"]}
            }
          },
          {
            "properties": {
              "resume_event": {"const": "timeout"},
              "wake_reason": {"const": "timeout"}
            }
          },
          {
            "properties": {
              "resume_event": {"const": "runtime_failure"},
              "wake_reason": {"const": "runtime_failure"}
            }
          },
          {
            "properties": {
              "resume_event": {"const": "cancellation"},
              "wake_reason": {"const": "cancellation"}
            }
          },
          {
            "properties": {
              "resume_event": {"const": "user_input"},
              "wake_reason": {"const": "user_input"}
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {"event": {"const": "coordinator_resumed"}},
        "required": ["event"]
      },
      "then": {
        "oneOf": [
          {
            "properties": {
              "wake_reason": {"enum": ["dependency_ready", "user_input"]},
              "projection": {
                "properties": {"status": {"const": "executing"}},
                "required": ["status"]
              }
            }
          },
          {
            "properties": {
              "wake_reason": {
                "enum": ["dispatch_blocked", "manual_blocked", "timeout", "runtime_failure"]
              },
              "projection": {
                "properties": {"status": {"const": "blocked"}},
                "required": ["status"]
              }
            }
          },
          {
            "properties": {
              "wake_reason": {"const": "cancellation"},
              "projection": {
                "properties": {"status": {"const": "cancelled"}},
                "required": ["status"]
              }
            }
          }
        ]
      }
    }
  ],
  "additionalProperties": false
}
